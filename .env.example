# Optional learned-detector switches. Defaults are off.
LEARNED_DETECTORS_ENABLED=false
D3_ENABLED=false
D3_DEVICE=auto
D3_ENCODER=XCLIP-16
D3_DISTANCE=l2
D3_RANDOM_SEED=42
D3_TIMEOUT_SECONDS=300
D3_ALLOW_MODEL_DOWNLOAD=false
D3_MODEL_CACHE_DIRECTORY=
D3_PREPROCESSING_MODE=upstream_compatible
D3_PRESERVE_TEMPORARY_FRAMES=false

# Compact Gemini-ready derivative report. This does not call Gemini.
GEMINI_COMPACT_REPORT_ENABLED=true
GEMINI_COMPACT_MAX_KEY_EVENTS=5
GEMINI_COMPACT_MAX_FINDINGS_PER_EVENT=5
GEMINI_COMPACT_MAX_ARTIFACTS_PER_EVENT=4
GEMINI_COMPACT_PREFERRED_SIZE_BYTES=8000
GEMINI_COMPACT_ACCEPTABLE_SIZE_BYTES=12000
GEMINI_COMPACT_HARD_SIZE_BYTES=16000
